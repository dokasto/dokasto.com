---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Comments from '../components/Comments.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  pubDate: Date;
}

const { title, description, pubDate } = Astro.props;
---

<BaseLayout title={`${title} | Udo Nkwocha`} description={description}>
  <link
    slot="head"
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css"
    integrity="sha384-n8MVd4RsNIU0tAv4ct0nTaAbDJwPJzDEaqSD1odI+WdtXRGWt2kTvGFasHpSy3SV"
    crossorigin="anonymous"
  />

  <Header />

    <main class="px-6 max-w-4xl mx-auto pb-16">
      <article class="prose prose-lg max-w-none">
        <header class="mb-8">
          <h1 class="text-3xl font-bold mb-2">{title}</h1>
          <time class="text-sm opacity-70" datetime={pubDate.toISOString()}>
            {pubDate.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric'
            })}
          </time>
        </header>

        <div class="blog-content">
          <slot />
        </div>
      </article>

      <Comments />
    </main>
</BaseLayout>

<style>
  :global(.blog-content p) {
    margin-bottom: 1rem;
    line-height: 1.7;
  }

  :global(.blog-content h2) {
    font-size: 1.5rem;
    font-weight: bold;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  :global(.blog-content h3) {
    font-size: 1.25rem;
    font-weight: bold;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }

  :global(.blog-content code) {
    background-color: rgba(0, 0, 0, 0.05);
    padding: 0.2rem 0.4rem;
    border-radius: 0.25rem;
    font-size: 0.9em;
  }

  :global(.blog-content pre) {
    background-color: rgba(0, 0, 0, 0.05);
    padding: 1rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    margin-bottom: 1rem;
  }

  :global(.blog-content pre code) {
    background-color: transparent;
    padding: 0;
  }

  :global(.blog-content a) {
    text-decoration: underline;
  }

  :global(.blog-content a:hover) {
    opacity: 0.7;
  }

  :global(.blog-content ul), :global(.blog-content ol) {
    margin-left: 1.5rem;
    margin-bottom: 1rem;
  }

  :global(.blog-content li) {
    margin-bottom: 0.5rem;
  }

  :global(.blog-content blockquote) {
    margin: 2rem auto;
    padding-left: 1.5rem;
    padding-top: 0.5rem;
    padding-bottom: 0.5rem;
    font-style: italic;
    opacity: 0.9;
    border-left: 3px solid currentColor;
    max-width: 80%;
  }

  :global(.blog-content blockquote p) {
    margin-bottom: 0.25rem;
  }

  :global(.blog-content blockquote p:last-child) {
    margin-bottom: 0;
  }
</style>
