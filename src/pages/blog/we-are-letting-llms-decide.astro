  data={rubricDataWithEvidence}
  defaultExpandedCategories={['Problem Solving']}
  defaultExpandedLevels={{ 'Problem Solving': ['Poor'] }}
  expandEvidenceByDefault={true}
  client:only="react"
/>

<p class="rubric-source">
