---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import '../styles/global.css';
import projectsData from '../data/projects.json';

// Manually define blog posts (add new posts here)
const blogPosts = [
  {
    slug: 'we-are-letting-llms-decide',
    title: "We are Letting LLMs Decide Who Gets Hired and Doing It Wrong",
    pubDate: new Date('2026-01-26')
  }
].sort((a, b) => b.pubDate.valueOf() - a.pubDate.valueOf());

const projects = projectsData.projects;
---

<BaseLayout
  title="Udo Nkwocha"
  description="Udo Nkwocha's blog - Technical thoughts and explorations"
>
  <Header />

    <main class="px-6 max-w-6xl mx-auto pb-16">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_400px] gap-8 lg:gap-12">

        <!-- Blog Posts Column (LEFT) -->
        <section aria-label="Blog posts">
          <div class="space-y-8">
            {blogPosts.map((post) => (
              <article class="border-b border-current/20 pb-6">
                <a href={`/blog/${post.slug}/`} class="block hover:opacity-70 transition-opacity">
                  <h2 class="text-xl font-bold mb-2">{post.title}</h2>
                  <time class="text-sm opacity-70" datetime={post.pubDate.toISOString()}>
                    {post.pubDate.toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric'
                    })}
                  </time>
                </a>
              </article>
            ))}
          </div>
        </section>

        <!-- Projects Column (RIGHT) -->
        <section aria-labelledby="projects-heading" class="lg:sticky lg:top-6 lg:self-start">
          <h2 id="projects-heading" class="text-xl font-bold mb-6">Projects</h2>
          <div class="space-y-6">
            {projects.map((project) => (
              <article class="border-b border-current/20 pb-6 last:border-b-0">
                <h3 class="text-base font-bold mb-2">{project.title}</h3>
                <p class="text-sm opacity-80 mb-3">{project.description}</p>
                <div class="flex gap-3">
                  {project.web && (
                    <a
                      href={project.web}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-xs opacity-70 hover:opacity-100 transition-opacity inline-flex items-center gap-1"
                    >
                      <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                      </svg>
                      <span>View website</span>
                      <span class="sr-only">(opens in new tab)</span>
                    </a>
                  )}
                  {project.github && (
                    <a
                      href={project.github}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-xs opacity-70 hover:opacity-100 transition-opacity inline-flex items-center gap-1"
                    >
                      <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                      </svg>
                      <span>View on GitHub</span>
                      <span class="sr-only">(opens in new tab)</span>
                    </a>
                  )}
                </div>
              </article>
            ))}
          </div>
        </section>

      </div>
    </main>
</BaseLayout>
